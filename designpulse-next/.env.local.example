# Copy to .env.local (git-ignored) and fill in real values.
# .env.local is consumed by Next.js, and loaded by vitest.config.ts / playwright.config.ts
# for the integration and E2E suites.

# Supabase connection (client-safe anon key)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Dedicated test account for integration + E2E suites and the load-test scripts.
# Use a throwaway test user, NOT a personal/admin login. Never commit real values.
TEST_USER_EMAIL=test-user@example.com
TEST_USER_PASSWORD=change-me

# Optional — integration test scoping/capabilities.
# A throwaway project the test account may write to. When set, the financial
# immutability tests run and scope their writes to this project; when unset they
# skip entirely (the suite never touches arbitrary production data by default).
# TEST_SANDBOX_PROJECT_ID=
# 'true' if the test account is a platform admin (tightens the RBAC assertions).
# TEST_USER_IS_PLATFORM_ADMIN=false
